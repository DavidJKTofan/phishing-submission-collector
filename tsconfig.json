{
	"compilerOptions": {
		"allowJs": false,
		"checkJs": false,
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"noImplicitAny": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["./worker-configuration.d.ts"]
	},
	"include": ["src/**/*.ts", "worker-configuration.d.ts"]
}
