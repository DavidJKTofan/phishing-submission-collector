# Cloudflare Workers static-asset response headers.
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/
#
# Under default (asset-first) routing this file is authoritative for static
# pages — the Worker's fetch handler only runs for non-asset paths and the
# 404 fallback. Keep these values in sync with SECURITY_HEADERS / HTML_CSP in src.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), browsing-topics=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains

# CSP on the submission page. index.html has no inline <style>/style="" so it
# does not need style-src 'unsafe-inline' (JS .style.* is CSSOM, not governed by
# CSP). Allows the Turnstile script and iframe from challenges.cloudflare.com.
/
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'; upgrade-insecure-requests

/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'; upgrade-insecure-requests

# report.html uses an inline <style> block and style="" attributes, so it
# requires style-src 'unsafe-inline'. It needs no Turnstile origins.
/report
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'; upgrade-insecure-requests

/report.html
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'; upgrade-insecure-requests
