{
  "name": "phish-submission-collector",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types --config wrangler.jsonc",
    "check": "npm run typecheck && tsc -p tests/tsconfig.json --noEmit && node --check public/assets/scripts.js && node --check public/assets/report.js && node --check public/assets/theme.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "wrangler d1 migrations apply reports_db --remote --config wrangler.jsonc",
    "migrate:staging": "wrangler d1 migrations apply reports_db_staging --remote --config wrangler.jsonc --env staging",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "deploy:staging": "wrangler deploy --config wrangler.jsonc --env staging",
    "deploy:dry-run": "wrangler deploy --dry-run --config wrangler.jsonc",
    "deploy:staging:dry-run": "wrangler deploy --dry-run --config wrangler.jsonc --env staging",
    "dev": "wrangler dev --config wrangler.jsonc",
    "dev:staging": "wrangler dev --config wrangler.jsonc --env staging",
    "start": "wrangler dev --config wrangler.jsonc",
    "typecheck": "npm run cf-typegen && tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "~4.1.9",
    "wrangler": "^4.103.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true,
    "workerd@1.20260617.1": true
  }
}
